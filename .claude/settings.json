{
  "permissions": {
    "allow": [
      "Bash(python3)",
      "WebFetch(domain:docs.weblate.org)",
      "WebSearch"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/auxiliary/fetch_confluence.py",
            "timeout": 15,
            "statusMessage": "Fetching Checkmk Dictionary from Confluence..."
          }
        ]
      }
    ]
  }
}
